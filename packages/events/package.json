{
  "name": "@opencrvs/events",
  "version": "1.9.13",
  "description": "OpenCRVS Events service",
  "license": "MPL-2.0",
  "private": true,
  "scripts": {
    "start": "concurrently 'cross-env NODE_ENV=development NODE_OPTIONS=--dns-result-order=ipv4first nodemon -r tsconfig-paths/register src/index.ts' 'tsc -w -p tsconfig.router.json --preserveWatchOutput'",
    "start:prod": "TS_NODE_BASEURL=./build/dist/src node -r tsconfig-paths/register build/dist/src/index.js",
    "test": "yarn test:compilation && vitest run --coverage",
    "test:watch": "vitest",
    "lint": "CI=true eslint -c eslint.config.js --fix --max-warnings=0",
    "precommit": "lint-staged",
    "test:compilation": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.router.json",
    "build:types": "tsc -p tsconfig.router.json",
    "build:clean": "rm -rf build",
    "generate-db-types": "kanel && prettier src/storage/postgres/events/schema --write",
    "generate-db-schema": "bash src/tests/generate-db-schema.sh"
  },
  "dependencies": {
    "@elastic/elasticsearch": "8.16.2",
    "@opencrvs/commons": "^1.9.0",
    "@trpc/server": "^11.8.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/luxon": "^3.6.2",
    "@types/pg": "^8.15.4",
    "@types/pg-cursor": "^2.7.2",
    "app-module-path": "^2.2.0",
    "bcryptjs": "^2.4.3",
    "envalid": "^8.0.0",
    "json-stream-stringify": "^3.1.6",
    "jsonwebtoken": "^9.0.0",
    "kysely": "^0.28.2",
    "lodash": "^4.17.21",
    "luxon": "^3.6.1",
    "msw": "^2.7.3",
    "node-fetch": "^2.6.7",
    "pg": "^8.16.0",
    "pg-cursor": "^2.15.3",
    "pg-query-stream": "^4.10.0",
    "superjson": "1.9.0-0",
    "trpc-to-openapi": "^3.2.0",
    "tsconfig-paths": "^3.13.0",
    "zod": "^4.2.1",
    "zod-form-data": "3.0.1",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.7",
    "@eslint/eslintrc": "^3.3.1",
    "@testcontainers/elasticsearch": "^10.15.0",
    "@testcontainers/postgresql": "^11.0.3",
    "@trpc/client": "^11.2.0",
    "@types/busboy": "*",
    "@types/jsonwebtoken": "^9.0.10",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitest/coverage-v8": "2.1.5",
    "cross-env": "^7.0.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.3.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.5",
    "fast-check": "^4.3.0",
    "globals": "^16.0.0",
    "kanel": "^3.14.1",
    "kanel-kysely": "^0.7.1",
    "kysely-codegen": "^0.18.5",
    "lint-staged": "^15.0.0",
    "nodemon": "^3.0.0",
    "prettier": "3.5.3",
    "testcontainers": "^10.15.0",
    "ts-jest": "27.1.4",
    "ts-node": "^6.1.1",
    "typescript": "5.6.3",
    "vite-tsconfig-paths": "^3.5.0",
    "vitest": "2.1.9",
    "yaml": "^2.7.1"
  },
  "exports": {
    "./src/router": {
      "types": "./build/types/router.d.ts"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,graphql}": [
      "prettier --write",
      "eslint -c eslint.config.js --fix"
    ]
  }
}
